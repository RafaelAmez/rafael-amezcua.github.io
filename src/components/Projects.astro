---
import { Image } from 'astro:assets';
import meImg from '../assets/images/Me.JPG';
import bartImg from '../assets/images/Bart.jpg';
import clothesImg from '../assets/images/Clothes.jpg';
---

<section id="projects">
  <div class="container">
    <p class="s-label fade-in">Selected Work</p>
    <h2 class="s-title fade-in">Projects & Branding</h2>
    <div class="s-divider fade-in"></div>
    <div class="proj-grid">

      <!-- Intertwine Fitness -->
      <div class="proj-card wide fade-in">
        <!-- Browser chrome wrapper -->
        <div class="if-preview">
          <div class="if-chrome">
            <div class="if-chrome-dots">
              <span style="background:#ff5f57"></span>
              <span style="background:#febc2e"></span>
              <span style="background:#28c840"></span>
            </div>
            <div class="if-chrome-bar">
              <span class="if-chrome-url">intertwinefitness.com</span>
            </div>
          </div>
          <!-- Site mockup -->
          <div class="if-site-preview">
            <img src="/if-stock1.png" alt="Intertwine Fitness" class="if-bg-img" />
            <div class="if-site-overlay"></div>
            <!-- Top nav -->
            <div class="if-site-nav">
              <div class="if-nav-logo">
                <img src="/if-logo.png" alt="IF" style="width:28px;height:28px;object-fit:contain;" />
              </div>
              <div class="if-nav-links">
                <span class="if-nav-active">ABOUT</span>
                <span>PROCESS</span>
                <span>RESULTS</span>
                <span>SERVICES</span>
              </div>
              <div class="if-nav-cta">BOOK A CONSULT</div>
            </div>
            <!-- Location line -->
            <div class="if-location">SAN DIEGO, CA &nbsp;·&nbsp; ONLINE &amp; IN-PERSON</div>
            <!-- Hero text -->
            <div class="if-hero-text">
              <div class="if-headline">You've done the work.<br/>Let's make it <em>stick.</em></div>
            </div>
          </div>
        </div>
        <div class="proj-body">
          <div class="proj-tags">
            <span class="tag">Brand Identity</span>
            <span class="tag">Logo Design</span>
            <span class="tag">Web Design</span>
            <span class="tag">Illustrator</span>
            <span class="tag">In Progress</span>
          </div>
          <div class="proj-title" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:0.5rem;">
            Intertwine Fitness
            <a
              href="https://www.intertwinefitness.com"
              target="_blank"
              style="font-size:0.78rem;font-weight:700;color:var(--terra);text-decoration:none;border:1px solid rgba(13,110,79,0.3);padding:0.25rem 0.8rem;border-radius:0.3rem;transition:all 0.2s;"
              onmouseover="this.style.background='rgba(13,110,79,0.1)'"
              onmouseout="this.style.background='transparent'"
            >View Site →</a>
          </div>
          <p class="proj-desc">
            <strong>Problem:</strong> A local fitness brand had no visual identity — no logo, no color system, no way to stand out in a crowded market.<br/>
            <strong>Built:</strong> Designed the full brand identity from scratch — wordmark, logo system, color palette, and typography — using Illustrator with a focus on strength, connectivity, and movement.<br/>
            <strong>Result:</strong> A cohesive, production-ready brand system currently live at intertwinefitness.com.
          </p>
        </div>
      </div>

      <!-- Cycle Care -->
      <div class="proj-card fade-in">
        <div class="proj-thumb cc">
          <div class="carousel-track" id="carousel-cc">
            <div class="carousel-slide">
              <Image src={meImg} alt="Cycle Care event" width={600} height={400} quality={80} loading="eager" style="object-position:center 30%;" />
            </div>
            <div class="carousel-slide">
              <Image src={bartImg} alt="Cycle Care volunteer" width={600} height={400} quality={80} style="object-position:center 30%;" />
            </div>
            <div class="carousel-slide">
              <Image src={clothesImg} alt="Cycle Care clothing collection" width={600} height={400} quality={80} style="object-position:center 1%;" />
            </div>
          </div>
          <button class="carousel-btn prev" onclick="moveCarousel('cc',-1)">&#8249;</button>
          <button class="carousel-btn next" onclick="moveCarousel('cc',1)">&#8250;</button>
          <div class="carousel-dots" id="dots-cc">
            <div class="dot active" onclick="goToSlide('cc',0)"></div>
            <div class="dot" onclick="goToSlide('cc',1)"></div>
            <div class="dot" onclick="goToSlide('cc',2)"></div>
          </div>
        </div>
        <div class="proj-body">
          <div class="proj-tags">
            <span class="tag">Sustainability</span>
            <span class="tag">Campaign Strategy</span>
            <span class="tag">Marketing</span>
          </div>
          <div class="proj-title">Cycle Care</div>
          <p class="proj-desc">
            <strong>Problem:</strong> Textile waste at community colleges goes largely unaddressed — students discard clothing with no sustainable alternative.<br/>
            <strong>Built:</strong> Founded and led Cycle Care at SDCC — developed the brand strategy, messaging framework, outreach materials, and coordinated collection events to drive community participation.<br/>
            <strong>Result:</strong> Measurable community impact documented in a formal impact report, with student engagement across campus.
          </p>
          <a
            href="/docs/Winnie and Rafael Final Impact Report.pdf"
            target="_blank"
            style="display:inline-block;margin-top:1rem;background:var(--terra);color:var(--cream);padding:0.5rem 1.2rem;border-radius:0.4rem;font-size:0.82rem;font-weight:700;text-decoration:none;"
          >View Impact Report →</a>
        </div>
      </div>

      <!-- Nymbus -->
      <div class="proj-card wide fade-in">
        <div class="nymbus-preview">
          <!-- Browser chrome -->
          <div class="nymbus-chrome">
            <div class="nymbus-dots">
              <span style="background:#ff5f57"></span>
              <span style="background:#febc2e"></span>
              <span style="background:#28c840"></span>
            </div>
            <!-- Tab switcher -->
            <div class="nymbus-tabs">
              <button class="nymbus-tab active" data-tab="dashboard" onclick="nymbusTab('dashboard',this)">Dashboard</button>
              <button class="nymbus-tab" data-tab="kanban" onclick="nymbusTab('kanban',this)">Kanban</button>
            </div>
            <div style="display:flex;align-items:center;gap:5px;background:#ebebeb;border-radius:6px;padding:3px 10px;margin-left:auto;">
              <img src="/nymbus-logo.png" style="width:12px;height:12px;border-radius:3px;" alt="" />
              <span style="font-size:10px;color:#555;font-weight:600;">nymbus.pro</span>
            </div>
          </div>

          <!-- Dashboard tab -->
          <div class="nymbus-tab-panel" id="tab-dashboard">
            <div class="nymbus-stats">
              <div class="nymbus-stat-card" style="--c:#7f77dd;--bg:#f8f7ff;--br:#e8e6ff;">
                <div class="nymbus-stat-label">Applications</div>
                <div class="nymbus-stat-val" id="nymbus-stat-total">—</div>
              </div>
              <div class="nymbus-stat-card" style="--c:#d4a847;--bg:#fffbf0;--br:#f0e8cc;">
                <div class="nymbus-stat-label">Interviews</div>
                <div class="nymbus-stat-val" id="nymbus-stat-interviews">—</div>
              </div>
              <div class="nymbus-stat-card" style="--c:#6a9fd8;--bg:#f0f8ff;--br:#cce0f5;">
                <div class="nymbus-stat-label">Users</div>
                <div class="nymbus-stat-val" style="color:#6a9fd8;">Live</div>
              </div>
              <div class="nymbus-stat-card" style="--c:#5aad6a;--bg:#f0fff4;--br:#b2e8be;">
                <div class="nymbus-stat-label">Offers</div>
                <div class="nymbus-stat-val" id="nymbus-stat-offers">—</div>
              </div>
            </div>
            <div class="nymbus-rows">
              <div class="nymbus-row" style="border-left-color:#d4a847;">
                <div class="nymbus-avatar" style="background:#7f77dd;">P</div>
                <span class="nymbus-row-name">Precisely</span>
                <span class="nymbus-badge" style="color:#6a9fd8;background:#e8f2fc;">Interview</span>
              </div>
              <div class="nymbus-row" style="border-left-color:#5aad6a;">
                <div class="nymbus-avatar" style="background:#5aad6a;">M</div>
                <span class="nymbus-row-name">Mercury Health</span>
                <span class="nymbus-badge" style="color:#5aad6a;background:#e8f5ec;">Offer</span>
              </div>
              <div class="nymbus-row" style="border-left-color:#aaa;">
                <div class="nymbus-avatar" style="background:#bbb;">A</div>
                <span class="nymbus-row-name">Apex Solutions</span>
                <span class="nymbus-badge" style="color:#aaa;background:#f2f2f2;">Applied</span>
              </div>
            </div>
          </div>

          <!-- Kanban tab -->
          <div class="nymbus-tab-panel" id="tab-kanban" style="display:none;">
            <div class="nymbus-kanban">
              <div class="kanban-col">
                <div class="kanban-col-header" style="color:#aaa;">Applied</div>
                <div class="kanban-card"><div class="kanban-avatar" style="background:#bbb;">A</div>Apex Solutions</div>
                <div class="kanban-card"><div class="kanban-avatar" style="background:#c46a6a;">R</div>Redline Corp</div>
              </div>
              <div class="kanban-col">
                <div class="kanban-col-header" style="color:#d4a847;">Interview</div>
                <div class="kanban-card" style="border-color:#d4a847;"><div class="kanban-avatar" style="background:#7f77dd;">P</div>Precisely</div>
              </div>
              <div class="kanban-col">
                <div class="kanban-col-header" style="color:#5aad6a;">Offer</div>
                <div class="kanban-card" style="border-color:#5aad6a;"><div class="kanban-avatar" style="background:#5aad6a;">M</div>Mercury Health</div>
              </div>
            </div>
          </div>

        </div>
        <div class="proj-body">
          <div class="proj-tags">
            <span class="tag">Full-Stack</span>
            <span class="tag">Node.js</span>
            <span class="tag">PostgreSQL</span>
            <span class="tag">JavaScript</span>
            <span class="tag">PWA</span>
            <span class="tag">REST API</span>
            <span class="tag">Deployed</span>
          </div>
          <div class="proj-title" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:0.5rem;">
            Nymbus
            <a
              href="https://nymbus.pro"
              target="_blank"
              style="font-size:0.78rem;font-weight:700;color:var(--terra);text-decoration:none;border:1px solid rgba(13,110,79,0.3);padding:0.25rem 0.8rem;border-radius:0.3rem;transition:all 0.2s;"
              onmouseover="this.style.background='rgba(13,110,79,0.1)'"
              onmouseout="this.style.background='transparent'"
            >View Live →</a>
          </div>
          <p class="proj-desc">
            <strong>Problem:</strong> Tracking job applications in a spreadsheet meant losing context, missing follow-ups, and no visibility into your pipeline.<br/>
            <strong>Built:</strong> A full-stack PWA with Node.js/Express, PostgreSQL, JWT auth with email verification, Kanban board, interview calendar, analytics dashboard, CSV export, and a bookmarklet for one-click saving from any job board.<br/>
            <strong>Result:</strong> Launched to real users — tracking <span id="nymbus-desc-total">hundreds of</span> applications across the platform.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  @keyframes pulse-dot {
    0% { box-shadow: 0 0 0 0 rgba(90,173,106,0.4); }
    70% { box-shadow: 0 0 0 6px rgba(90,173,106,0); }
    100% { box-shadow: 0 0 0 0 rgba(90,173,106,0); }
  }
</style>

<script is:inline>
  (function () {
    fetch('https://nymbus.pro/stats/public')
      .then(r => r.json())
      .then(data => {
        const total = data.total || 0;
        const interviews = data.interviews || 0;
        const el = document.getElementById('nymbus-stat-total');
        const eli = document.getElementById('nymbus-stat-interviews');
        const eld = document.getElementById('nymbus-desc-total');
        if (el) el.textContent = total.toLocaleString();
        if (eli) eli.textContent = interviews.toLocaleString();
        if (eld) eld.textContent = total.toLocaleString();
      })
      .catch(() => {});
  })();
</script>
